# App runtime
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Supabase CLI (required for migration/list/link)
SUPABASE_ACCESS_TOKEN="<personal-access-token>"
SUPABASE_DB_PASSWORD="<project-db-password>"

# PII 암호화 키 (AES-256-GCM, base64 인코딩, 32바이트)
# openssl rand -base64 32 으로 생성
PII_ENCRYPTION_KEY_BASE64="<base64-encoded-32-byte-key>"

# Sentry 에러 모니터링 (https://sentry.io 에서 프로젝트 생성 후 DSN 복사)
# NEXT_PUBLIC_SENTRY_DSN 은 클라이언트에 노출되는 값이므로 비밀이 아님
NEXT_PUBLIC_SENTRY_DSN="https://<key>@<org>.ingest.sentry.io/<project-id>"
# 소스맵 업로드 시 필요 (Sentry Settings > Auth Tokens)
SENTRY_AUTH_TOKEN="<sentry-auth-token>"
# staging | production | development
NEXT_PUBLIC_APP_ENV="development"

# Optional
SUPABASE_STORAGE_BUCKET="case-files"
# Set to "true" to enable maintenance mode (redirects all requests to /maintenance)
MAINTENANCE_MODE="false"
