{
  "name": "vein-spiral-p0-foundation",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "check:migrations": "node ./scripts/check-migrations.mjs",
    "check:audit-traceability": "node ./scripts/check-audit-traceability.mjs",
    "check:test-coverage": "node ./scripts/check-test-coverage.mjs",
    "check:rehab-integrity": "node ./scripts/check-rehab-data-integrity.mjs",
    "check:all": "pnpm check:migrations && pnpm check:audit-traceability && pnpm check:test-coverage && pnpm check:rehab-integrity && pnpm check:rule-meta && pnpm check:ai-guardrails && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "검사돌아": "pnpm check:all",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "pnpm test:e2e:public-smoke",
    "test:e2e:public-smoke": "playwright test --config=playwright.config.ts",
    "test:e2e:prod-smoke": "pnpm build && playwright test --config=playwright.prod-smoke.config.ts",
    "test:e2e:auth-prod-smoke": "pnpm build && playwright test --config=playwright.authenticated-prod-smoke.config.ts",
    "typecheck": "next typegen && tsc --noEmit",
    "ops:preflight": "node ./scripts/preflight-env.mjs",
    "git:main:sync": "./scripts/main-sync.sh",
    "supabase:projects": "./scripts/run-with-env.sh supabase projects list",
    "supabase:migration:list": "./scripts/run-with-env.sh supabase migration list",
    "supabase:db:push": "./scripts/run-with-env.sh supabase db push",
    "check:rule-meta": "node ./scripts/check-rule-meta.mjs",
    "check:ai-guardrails": "node ./scripts/check-ai-guardrails.mjs",
    "check:navigation-consistency": "node ./scripts/check-navigation-consistency.mjs",
    "check:schema-drift": "node ./scripts/check-schema-drift.mjs",
    "types:check": "node ./scripts/check-supabase-types.mjs check",
    "types:gen": "node ./scripts/check-supabase-types.mjs gen"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.45.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "lucide-react": "^0.482.0",
    "next": "16.1.6",
    "pdf-lib": "^1.17.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^3.0.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
